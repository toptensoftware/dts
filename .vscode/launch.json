{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\index.js",
            "cwd": "${workspaceFolder}/../shownotes-dev/cantabile-js",
            "args": [ 
                "flatten", 
                "@toptensoftware/cantabile-js",
                "./src/types.d.ts",
                "./types/*.d.ts", 
                "--out:types.d.ts",
                ]
            /*
            "args": [
                "extract",
                "types.d.ts",
                "--out:types.d.json",
            ]
            */
            /*
            "args": [
                "list-map", "types.d.ts.map",
            ]
            */
        }
    ]
}